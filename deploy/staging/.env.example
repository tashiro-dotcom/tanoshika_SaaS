# Local Step A defaults. For local compose, keep APP_DOMAIN/NEXT_PUBLIC_API_BASE_URL on http://localhost.
# For VPS Step B, set APP_DOMAIN to your staging domain (for example: staging.example.com)
# and NEXT_PUBLIC_API_BASE_URL to https://<that-domain> before booting Caddy.
APP_DOMAIN=http://localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost

# Keep 3001 in staging. Caddy upstream is fixed to api:3001.
PORT=3001
POSTGRES_DB=support_mgmt
POSTGRES_USER=app
POSTGRES_PASSWORD=app
DATABASE_URL=postgresql://app:app@postgres:5432/support_mgmt?schema=public

JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
MUNICIPALITY_TEMPLATE=fukuoka

BASIC_AUTH_USER=staging
# Plaintext password is used only by local-verify.sh. Keep it out of shared screenshots/docs.
BASIC_AUTH_PASSWORD=replace-me
# Generate hash from BASIC_AUTH_PASSWORD with:
# docker run --rm caddy:2 caddy hash-password --plaintext 'replace-me'
# In .env, escape each "$" as "$$" before saving the hash because docker compose interpolates "$".
BASIC_AUTH_PASSWORD_HASH=REPLACE_WITH_CADDY_HASH
